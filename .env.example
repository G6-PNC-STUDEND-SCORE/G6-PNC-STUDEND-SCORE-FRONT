# API base URL for frontend to call Laravel backend
# Must include /api (backend routes/api.php)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Google OAuth Client ID
# Get from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Sheets API OAuth redirect URI (must match Google Cloud Console)
# For development: http://localhost:5173/oauth2callback
# For production: https://your-domain.com/oauth2callback
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth2callback

